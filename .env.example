# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://retailpool:retailpool@localhost:5432/retailpool

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── Security (MVP static API key) ────────────────────────
API_KEY=change-me-in-production

# ── Proxy Provider ────────────────────────────────────────
# Example for SmartProxy / Bright Data / Proxy-Seller
PROXY_PROVIDER_API_URL=
PROXY_PROVIDER_API_KEY=
PROXY_COUNTRY=kz

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Success Fee ───────────────────────────────────────────
SUCCESS_FEE_PERCENT=3.0

# ── Scraper ───────────────────────────────────────────────
SCRAPER_MIN_DELAY=2.0
SCRAPER_MAX_DELAY=5.0
SCRAPER_HEADLESS=true
